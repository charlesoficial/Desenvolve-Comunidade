    --audio-player-play-color: #fff;\n    --audio-player-progress-color: var(--audio-player-play-background);\n    --audio-player-progress-track-background: var(--color-border-primary, #e4e7eb);\n    background: transparent; width: 100%; min-width: 0; max-width: 100%; display: block; overflow: hidden;\n  }\n  .shell {\n    position: relative;\n    display: flex; flex-direction: row; align-items: center; width: 100%;\n    min-width: 0; max-width: 100%;\n    min-height: 120px; padding: 16px;\n    background: var(--audio-player-surface); border: 1px solid var(--color-border-primary, #e4e7eb); border-radius: var(--border-radius-2xl, 16px); overflow: hidden; box-sizing: border-box;\n  }\n  .poster-panel {\n    flex-shrink: 0; width: 88px; height: 88px; position: relative;\n  }\n  .desktop-layout {\n    flex: 1 1 0; display: flex; align-items: center; min-width: 0; max-width: 100%;\n  }\n  .cover-art {\n    width: 100%; height: 100%; display: block;\n    border-radius: var(--border-radius-lg, 8px); object-fit: cover;\n  }\n  .mobile-layout, .mobile-top, .mobile-meta, .mobile-progress-row { display: none; }\n  .play-column {\n    flex-shrink: 0; width: 96px; padding: 0 16px 0 12px; box-sizing: border-box;\n    display: flex; align-items: center; justify-content: center;\n  }\n  .shell:not(:has(.poster-panel)) .play-column {\n    padding-left: 0;\n  }\n  .body {\n    flex: 1 1 0; display: flex; flex-direction: column; justify-content: center;\n    width: 0; min-width: 0; max-width: 100%; overflow: hidden;\n  }\n  .top { display: flex; align-items: center; min-height: 24px; width: 100%; min-width: 0; max-width: 100%; overflow: hidden; }\n  media-play-button {\n    --media-button-icon-width: 24px; --media-button-icon-height: 24px;\n    --media-icon-color: var(--audio-player-play-color);\n    flex-shrink: 0; width: 64px; height: 64px;\n    background: var(--audio-player-play-background);\n    border-radius: 9999px; color: var(--audio-player-play-color); transition: filter 0.15s ease;\n  }\n  media-play-button:hover { filter: brightness(0.96); }\n  media-play-button :is(#icon-play, #icon-pause) {\n    transform-box: fill-box;\n    transform-origin: center;\n    transition: transform 0.2s ease-out, opacity 0.15s ease;\n  }\n  media-play-button #icon-play {\n    transform: scale(1);\n  }\n  media-play-button #icon-pause {\n    transform: scale(0.75);\n    opacity: 0;\n  }\n  media-play-button:not([mediapaused]) #icon-play {\n    transform: scale(0.75);\n    opacity: 0;\n  }\n  media-play-button:not([mediapaused]) #icon-pause {\n    transform: scale(1);\n    opacity: 1;\n  }\n  .track-title {\n    font-family: var(--media-font-family);\n    font-size: 14px; line-height: 20px; letter-spacing: 0; font-weight: 600; color: var(--audio-player-title-color);\n    display: block; width: 100%; max-width: 100%;\n    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1 1 0; min-width: 0;\n  }\n  media-time-range {\n    width: 100%; height: 6px; display: block;\n    --media-range-track-background: var(--audio-player-progress-track-background);\n    --media-range-bar-color: var(--audio-player-progress-color);\n    --media-range-bar-border-radius: 16px;\n    --media-range-thumb-background: var(--audio-player-progress-color);\n    --media-range-thumb-transform: scale(0);\n    --media-range-thumb-transition: transform 0.1s;\n    --media-range-thumb-width: 8px;\n    --media-range-thumb-height: 14px;\n    --media-range-thumb-border-radius: 9999px;\n    --media-range-track-height: 6px;\n    --media-range-track-border-radius: 16px;\n  }\n  media-time-range:hover { --media-range-thumb-transform: scale(1); }\n  media-time-range::part(track),\n  media-time-range::part(progress) {\n    border-radius: 16px;\n  }\n  .desktop-range {\n    position: absolute;\n    left: 16px;\n    right: 16px;\n    bottom: 0;\n    width: auto;\n    z-index: 0;\n  }\n  .controls { display: flex; align-items: center; gap: 0px; margin-left: -7px; width: calc(100% + 7px); min-width: 0; }\n  .spacer { flex: 1 1 0; min-width: 0; }\n  media-playback-rate-button, media-seek-backward-button, media-seek-forward-button, media-mute-button {\n    flex-shrink: 0; width: 32px; height: 32px; padding: 0; border-radius: var(--border-radius-lg, 8px);\n    border: none; background: transparent;\n    color: var(--audio-player-body-color);\n    --media-icon-color: var(--audio-player-body-color);\n    transition: color 0.1s ease;\n  }\n  media-playback-rate-button:hover, media-seek-backward-button:hover,\n  media-seek-forward-button:hover, media-mute-button:hover {\n    color: var(--audio-player-pill-hover-color);\n    --media-icon-color: var(--audio-player-pill-hover-color);\n  }\n  media-seek-backward-button, media-seek-forward-button, media-mute-button { --media-button-icon-width: 18px; --media-button-icon-height: 18px; }\n  media-mute-button :is(#icon-volume, #icon-muted) {\n    transition: opacity 0.15s ease;\n  }\n  media-mute-button #icon-muted {\n    opacity: 0;\n  }\n  media-mute-button[mediavolumelevel=\'off\'] #icon-volume {\n    opacity: 0;\n  }\n  media-mute-button[mediavolumelevel=\'off\'] #icon-muted {\n    opacity: 1;\n  }\n  media-playback-rate-button {\n    --media-button-icon-display: none;\n    font-family: var(--media-font-family);\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: auto;\n    min-width: 32px;\n    font-size: 14px; line-height: 1; font-weight: 600; padding: 0; letter-spacing: 0;\n  }\n  .dl {\n    flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center;\n    width: 32px; height: 32px; padding: 0; border-radius: var(--border-radius-lg, 8px);\n    border: none; background: transparent;\n    color: var(--audio-player-body-color);\n    text-decoration: none; transition: color 0.1s ease;\n  }\n  .dl:hover { color: var(--audio-player-pill-hover-color); }\n  .dl svg { width: 18px; height: 18px; display: block; }\n  media-time-display, media-duration-d