          var(--media-preview-border-radius) var(--media-preview-border-radius) 0 0);
      }

      :host([${ts.GC.MEDIA_PREVIEW_IMAGE}][dragging]) media-preview-thumbnail,
      :host([${ts.GC.MEDIA_PREVIEW_IMAGE}][dragging]) ::slotted(media-preview-thumbnail) {
