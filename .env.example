# Banco — Supabase Postgres via Transaction Pooler (porta 6543).
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
RAILS_MAX_THREADS=5

# Supabase — frontend (Vite) e bridge JWT no Rails.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_REST_URL=https://PROJECT_REF.supabase.co/rest/v1
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key

# Redis — Sidekiq + Action Cable. Se nao tiver Redis local, deixa em branco;
# o Rails detecta e usa :inline pra ActiveJob automaticamente.
REDIS_URL=redis://localhost:6379/1
DISABLE_SIDEKIQ=

# Stripe — Onda F. Sem chave o Checkout entra em modo "stub" (URL fake).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 — Onda E. Sem essas vars o backend grava em public/uploads.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_PUBLIC_URL=

# Producao (deploy Fly.io). Nao usar localmente.
APP_HOST=https://comunidade.com
RAILS_LOG_TO_STDOUT=
RAILS_SERVE_STATIC_FILES=
