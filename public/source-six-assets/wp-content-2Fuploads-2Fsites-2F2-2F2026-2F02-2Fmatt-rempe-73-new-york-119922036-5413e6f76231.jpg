<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, nofollow" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />
    <title>Verifying you are a human</title>
    <style>
      body {
        background-color: #fff;
        color: #fff;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        margin: 0;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
      }
      .container {
        text-align: center;
        padding: 24px;
        max-width: 600px;
        width: 100%;
      }
      .captcha-box {
        display: inline-block;
      }
      .darkBackground {
        background: radial-gradient(
            circle at top left,
            #4855bf 0%,
            rgb(45 28 105),
            rgba(28, 17, 68, 0) 60%
          ),
          radial-gradient(
            circle at bottom right,
            #2c256f 0%,
            rgba(28, 17, 68, 0) 20%
          ),
          linear-gradient(to bottom, #180e3a, #211450);
        background-size: cover;
        background-position: center;
      }
      .verifying {
        font-size: 24px;
        line-height: 32px;
        color: #ffffff;
        margin: 0 0 4px 0;
        padding: 0;
        font-weight: bold;
      }
      .may-take {
        font-size: 16px;
        line-height: 24px;
        color: #d2d7db;
        margin: 0 0 56px 0;
        padding: 0;
      }
      .review {
        font-size: 16px;
        line-height: 24px;
        color: #d2d7db;
        margin: 56px 0 0 0;
        padding: 0;
      }
      .logo {
        margin: 0 0 56px 0;
        padding: 0;
      }
    </style>
  <meta http-equiv="refresh" content="360"></head>
