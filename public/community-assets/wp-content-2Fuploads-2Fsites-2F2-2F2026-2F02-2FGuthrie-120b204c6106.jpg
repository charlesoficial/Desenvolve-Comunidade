      <p class="review" data-translate="review">
        We need to review the security of your connection before proceeding.
      </p>
    </div>
    <script>
      function getHostname() {
        try {
          return window.location.hostname;
        } catch {
          return "";
        }
      }

      var translations = {
        en: {
          verifying: "Verifying you are a human",
          "may-take": "This may take a few seconds.",
          review:
            getHostname() +
            " needs to review the security of your connection before proceeding.",
        },
        ar: {
          verifying: "التحقق من أنك إنسان",
          "may-take": "قد يستغرق هذا بضع ثوان.",
          review: getHostname() + " يحتاج إلى مراجعة أمان اتصالك قبل المتابعة.",
        },
        bg: {
          verifying: "Проверка, че сте човек",
          "may-take": "Това може да отнеме няколко секунди.",
          review:
            getHostname() +
            " трябва да прегледа сигурността на вашата връзка, преди да продължи.",
        },
        zh: {
          verifying: "验证您是人类",
          "may-take": "这可能需要几秒钟。",
          review: getHostname() + " 需要在继续之前检查您连接的安全性。",
        },
        hr: {
          verifying: "Potvrđujemo da ste čovjek",
          "may-take": "Ovo može potrajati nekoliko sekundi.",
          review:
            getHostname() +
            " treba pregledati sigurnost vaše veze prije nastavka.",
        },
        cs: {
          verifying: "Ověřujeme, že jste člověk",
          "may-take": "Může to trvat několik sekund.",
          review:
            getHostname() +
            " potřebuje před pokračováním zkontrolovat bezpečnost vašeho připojení.",
        },
        da: {
          verifying: "Verificerer at du er et menneske",
          "may-take": "Dette kan tage et par sekunder.",
          review:
            getHostname() +
            " skal gennemgå sikkerheden af din forbindelse, før du kan fortsætte.",
        },
        nl: {
          verifying: "Verifiëren dat u een mens bent",
          "may-take": "Dit kan een paar seconden duren.",
          review:
            getHostname() +
            " moet de beveiliging van uw verbinding controleren voordat u verder kunt gaan.",
        },
        fi: {
          verifying: "Varmistetaan, että olet ihminen",
          "may-take": "Tämä voi kestää muutaman sekunnin.",
          review:
            getHostname() +
            ":n täytyy tarkistaa yhteytesi turvallisuus ennen jatkamista.",
        },
        fr: {
          verifying: "Vérification que vous êtes humain",
          "may-take": "Cela peut prendre quelques secondes.",
          review:
            getHostname() +
            " doit vérifier la sécurité de votre connexion avant de continuer.",
        },
        de: {
          verifying: "Überprüfung, ob Sie ein Mensch sind",
          "may-take": "Dies kann einige Sekunden dauern.",
          review:
            getHostname() +
            " muss die Sicherheit Ihrer Verbindung überprüfen, bevor Sie fortfahren können.",
        },
        el: {
          verifying: "Επαλήθευση ότι είστε άνθρωπος",
          "may-take": "Αυτό μπορεί να διαρκέσει μερικά δευτερόλεπτα.",
          review:
            getHostname() +
            " πρέπει να ελέγξει την ασφάλεια της σύνδεσής σας πριν προχωρήσετε.",
        },
        he: {
          verifying: "מאמת שאתה אנושי",
          "may-take": "זה עשוי לקחת מספר שניות.",
          review:
            getHostname() + " צריך לבדוק את אבטחת החיבור שלך לפני שתמשיך.",
        },
        hi: {
          verifying: "सत्यापित किया जा रहा है कि आप मानव हैं",
          "may-take": "इसमें कुछ सेकंड लग सकते हैं।",
          review:
            getHostname() +
            " को जारी रखने से पहले आपके कनेक्शन की सुरक्षा की समीक्षा करने की आवश्यकता है।",
        },
        hu: {
          verifying: "Annak ellenőrzése, hogy Ön ember",
          "may-take": "Ez eltarthat néhány másodpercig.",
          review:
            getHostname() +
            "-nak ellenőriznie kell a kapcsolat biztonságát, mielőtt folytatná.",
        },
        id: {
          verifying: "Memverifikasi bahwa Anda adalah manusia",
          "may-take": "Ini mungkin memakan waktu beberapa detik.",
          review:
            getHostname() +
            " perlu meninjau keamanan koneksi Anda sebelum melanjutkan.",
        },
        it: {
          verifying: "Verifica che sei umano",
          "may-take": "Potrebbe richiedere alcuni secondi.",
          review:
            getHostname() +
            " deve esaminare la sicurezza della tua connessione prima di procedere.",
        },
        ja: {
          verifying: "人間であることを確認しています",
          "may-take": "これには数秒かかる場合があります。",
          review:
            getHostname() +
            " は続行する前に接続のセキュリティを確認する必要があります。",
        },
        ko: {
          verifying: "사람인지 확인하는 중",
          "may-take": "이 작업은 몇 초 정도 걸릴 수 있습니다.",
          review:
            getHostname() + "는 진행하기 전에 연결의 보안을 검토해야 합니다.",
        },
        lt: {
          verifying: "Tikrinama, ar esate žmogus",
          "may-take": "Tai gali užtrukti kelias sekundes.",
          review:
            getHostname() +
            " turi peržiūrėti jūsų ryšio saugumą prieš tęsiant.",
        },
        ms: {
          verifying: "Mengesahkan anda adalah manusia",
          "may-take": "Ini mungkin mengambil masa beberapa saat.",
          review:
            getHostname() +
            " perlu menyemak keselamatan sambungan anda sebelum meneruskan.",
        },
        no: {
          verifying: "Verifiserer at du er et menneske",
          "may-take": "Dette kan ta noen sekunder.",
          review:
            getHostname() +
            " må gjennomgå sikkerheten til forbindelsen din før du kan fortsette.",
        },
        pl: {
          verifying: "Weryfikacja, czy jesteś człowiekiem",
          "may-take": "To może potrwać kilka sekund.",
          review:
            getHostname() +
            " musi sprawdzić bezpieczeństwo Twojego połączenia przed kontynuowaniem.",
        },
        pt: {
          verifying: "Verificando se você é humano",
          "may-take": "Isso pode levar alguns segundos.",
          review:
            getHostname() +
            " precisa revisar a segurança da sua conexão antes de prosseguir.",
        },
        ro: {
          verifying: "Se verifică dacă sunteți om",
          "may-take": "Acest lucru poate dura câteva secunde.",
          review:
            getHostname() +
            " trebuie să revizuiască securitatea conexiunii dvs. înainte de a continua.",
        },
        ru: {
          verifying: "Проверка, что вы человек",
          "may-take": "Это может занять несколько секунд.",
          review:
            getHostname() +
            " необходимо проверить безопасность вашего соединения, прежде чем продолжить.",
        },
        sr: {
          verifying: "Проверавамо да ли сте човек",
          "may-take": "Ово може потрајати неколико секунди.",
          review:
            getHostname() +
            " мора да прегледа безбедност ваше везе пре него што настави.",
        },
        sk: {
          verifying: "Overuje sa, či ste človek",
          "may-take": "Môže to trvať niekoľko sekúnd.",
          review:
            getHostname() +
            " potrebuje skontrolovať bezpečnosť vášho pripojenia pred pokračovaním.",
        },
        sl: {
          verifying: "Preverjanje, ali ste človek",
          "may-take": "To lahko traja nekaj sekund.",
          review:
            getHostname() +
            " mora pred nadaljevanjem preveriti varnost vaše povezave.",
        },
        es: {
          verifying: "Verificando que eres humano",
          "may-take": "Esto puede tomar unos segundos.",
          review:
            getHostname() +
            " necesita revisar la seguridad de tu conexión antes de continuar.",
        },
        sv: {
          verifying: "Verifierar att du är en människa",
          "may-take": "Detta kan ta några sekunder.",
          review:
            getHostname() +
            " behöver granska säkerheten för din anslutning innan du fortsätter.",
        },
        tl: {
          verifying: "Bine-verify na ikaw ay tao",
          "may-take": "Maaaring tumagal ito ng ilang segundo.",
          review:
            "Kailangang suriin ng " +
            getHostname() +
            " ang seguridad ng iyong koneksyon bago magpatuloy.",
        },
        th: {
          verifying: "กำลังตรวจสอบว่าคุณเป็นมนุษย์",
          "may-take": "อาจใช้เวลาสักครู่",
          review:
            getHostname() +
            " จำเป็นต้องตรวจสอบความปลอดภัยของการเชื่อมต่อของคุณก่อนดำเนินการต่อ",
        },
        tr: {
          verifying: "İnsan olduğunuz doğrulanıyor",
          "may-take": "Bu birkaç saniye sürebilir.",
          review:
            getHostname() +
            ", devam etmeden önce bağlantınızın güvenliğini gözden geçirmesi gerekiyor.",
        },
        uk: {
          verifying: "Перевірка, що ви людина",
          "may-take": "Це може зайняти кілька секунд.",
          review:
            getHostname() +
            " потрібно перевірити безпеку вашого з'єднання перед тим, як продовжити.",
        },
        vi: {
          verifying: "Đang xác minh bạn là người",
          "may-take": "Điều này có thể mất vài giây.",
          review:
            getHostname() +
            " cần xem xét bảo mật kết nối của bạn trước khi tiếp tục.",
        },
      };

      function detectLanguage() {
        var userLang = navigator.language || navigator.userLanguage;
        var langCode = userLang.split("-")[0];
        return translations[langCode] ? langCode : "en";
      }

      function translatePage(lang) {
        var elements = document.querySelectorAll("[data-translate]");
        elements.forEach(element => {
          var key = element.getAttribute("data-translate");
          if (translations[lang] && translations[lang][key]) {
            element.textContent = translations[lang][key];
          }
        });
        document.documentElement.lang = lang;
      }

      var userLang = detectLanguage();
      translatePage(userLang);
    </script>
  </body>
</html>
